# Quickstart: Durable HITL Interrupts with Postgres Checkpointer
# Copy to `.env` and fill in your LangSmith key. Postgres runs locally via
# docker-compose, so no DB credentials are needed beyond the defaults below.

# --- Postgres (local docker-compose; defaults match docker-compose.yml) ---
DB_URI=postgresql://postgres:postgres@localhost:5432/postgres?sslmode=disable

# --- LangSmith (Lesson 4). The app runs fine WITHOUT these — tracing fails
# soft. Set them to do the Lesson 4 "find the run" step. ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...your_key_here...
LANGSMITH_PROJECT=quickstart-durable-hitl

# NOTE: there is intentionally NO LLM API key here. The durability demo uses
# deterministic graph nodes — no model call is required to prove that the
# interrupt survives a crash. Swapping in a real model is a one-line change
# (see migration-checklist.md), but it is OUT OF SCOPE for this Quickstart.
