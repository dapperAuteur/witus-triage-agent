# WitUS Triage Agent — environment variables.
# Copy to `.env.local` and fill in. See plans/user-tasks/01-provision-env-and-secrets.md.

# --- Database (this app's OWN Postgres — never the WitUS Inbox DB) ---
# Local dev:  postgresql://localhost:5432/witus_triage_agent
# Neon:       use the pooled string here, the direct string below.
STORAGE_DATABASE_URL=
# Direct/unpooled connection — used by `drizzle-kit migrate` and checkpointer DDL.
# Locally this can be the same value as STORAGE_DATABASE_URL.
STORAGE_DATABASE_URL_UNPOOLED=

# --- LLM ---
# Seven providers are supported. Pick one (or stack a fallback chain).
#
#   FREE (rate-limited, $0):
#     OLLAMA       - local, no API key, just a reachable base URL.
#     CEREBRAS     - hosted free tier, Llama 3.3 70B, daily quota.
#     OPENROUTER   - hosted free models (DeepSeek, Qwen, Llama variants).
#     MISTRAL      - hosted free tier, 1B tokens/month.
#     TOGETHER     - hosted free tier, Llama 3.3 70B Turbo.
#
#   PAID (per-token billing) — keep as emergency fallback or for quality runs:
#     ANTHROPIC    - Claude Sonnet 4.6 / Opus 4.7 / Haiku 4.5.
#     GOOGLE       - Gemini 2.5 Pro / Flash.
#
# At least one credential (or local Ollama) is required to run the graph.

# Paid (Claude / Gemini) — emergency fallback by default.
GEMINI_API_KEY=                 # https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=              # https://console.anthropic.com

# Free hosted tiers — sign up, paste keys.
CEREBRAS_API_KEY=               # https://cloud.cerebras.ai
OPENROUTER_API_KEY=             # https://openrouter.ai/keys
MISTRAL_API_KEY=                # https://console.mistral.ai
TOGETHER_API_KEY=               # https://api.together.ai/settings/api-keys

# Local Ollama (no key). Override if running on a non-default host.
OLLAMA_BASE_URL=http://localhost:11434

# Force a provider (one of: ollama, cerebras, openrouter, mistral, together,
# anthropic, google). Auto-detected from the paid keys above if unset.
TRIAGE_LLM_PROVIDER=

# Comma-separated fallback chain when the primary throws. Recommended for the
# deployed demo: openrouter,anthropic — OpenRouter catches Cerebras's daily
# quota, Anthropic catches anything that gets past OpenRouter as the paid
# emergency tier.
TRIAGE_FALLBACK_PROVIDERS=

# --- Observability (optional — the app runs fine without these) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=witus-triage-agent
LANGSMITH_TRACING=true

# --- Auth (NextAuth v4 — needed once the operator dashboard exists, Day 4+) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Optional in local dev; set explicitly in production to the canonical URL.
NEXTAUTH_URL=
# The single email allowed to sign in to the operator dashboard.
ADMIN_EMAIL=

# --- Inbox webhook auth (Day 4+) ---
# Shared HMAC secret signing the inbox -> /api/triage/start webhook.
# Generate: openssl rand -hex 32   (must match the value set in witus-inbox)
TRIAGE_INGEST_SECRET=

# --- SMS escalation (optional until the escalateSms tool, Day 4) ---
MOBILE_TEXT_ALERTS_API_KEY=
# JSON array of E.164 numbers, e.g. ["+15551234567"]
MOBILE_TEXT_ALERTS_RECIPIENTS=

# --- WitUS Inbox — outbound webhook for waitlist signups. Optional locally. ---
# Distinct from TRIAGE_INGEST_SECRET above (that is the inbound webhook).
INBOX_INGEST_URL=https://inbox.witus.online/api/ingest
INBOX_INGEST_SECRET=
INBOX_SOURCE_SLUG=witus-triage-agent
