# WitUS Triage Agent — environment variables.
# Copy to `.env.local` and fill in. See plans/user-tasks/01-provision-env-and-secrets.md.

# --- Database (this app's OWN Postgres — never the WitUS Inbox DB) ---
# Local dev:  postgresql://localhost:5432/witus_triage_agent
# Neon:       use the pooled string here, the direct string below.
STORAGE_DATABASE_URL=
# Direct/unpooled connection — used by `drizzle-kit migrate` and checkpointer DDL.
# Locally this can be the same value as STORAGE_DATABASE_URL.
STORAGE_DATABASE_URL_UNPOOLED=

# --- LLM ---
# The agent supports two providers. Provide at least one key.
#   Testing  -> GEMINI_API_KEY  (Gemini 2.5 Flash, free tier)
#   Launch   -> ANTHROPIC_API_KEY (Claude Sonnet 4.6)
# When both are set, Anthropic wins. Override with TRIAGE_LLM_PROVIDER.
GEMINI_API_KEY=                 # https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=              # https://console.anthropic.com
# Optional — "anthropic" or "google". Auto-detected from the keys if unset.
TRIAGE_LLM_PROVIDER=

# --- Observability (optional — the app runs fine without these) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=witus-triage-agent
LANGSMITH_TRACING=true

# --- Auth (NextAuth v4 — needed once the operator dashboard exists, Day 4+) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Optional in local dev; set explicitly in production to the canonical URL.
NEXTAUTH_URL=
# The single email allowed to sign in to the operator dashboard.
ADMIN_EMAIL=

# --- Inbox webhook auth (Day 4+) ---
# Shared HMAC secret signing the inbox -> /api/triage/start webhook.
# Generate: openssl rand -hex 32   (must match the value set in witus-inbox)
TRIAGE_INGEST_SECRET=

# --- SMS escalation (optional until the escalateSms tool, Day 4) ---
MOBILE_TEXT_ALERTS_API_KEY=
# JSON array of E.164 numbers, e.g. ["+15551234567"]
MOBILE_TEXT_ALERTS_RECIPIENTS=

# --- WitUS Inbox — outbound webhook for waitlist signups. Optional locally. ---
# Distinct from TRIAGE_INGEST_SECRET above (that is the inbound webhook).
INBOX_INGEST_URL=https://inbox.witus.online/api/ingest
INBOX_INGEST_SECRET=
INBOX_SOURCE_SLUG=witus-triage-agent
